---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hayden Porter — Portfolio',
  description = 'AET @ UT Austin. Game Dev. Digital Creator. World-maker.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <nav class="site-nav">
      <div class="site-nav__inner">
        <div class="site-nav__brand-slot">
          <span class="site-nav__label">Creative Portfolio</span>
        </div>
        <div class="site-nav__links">
          <div class="site-nav__hover-box" aria-hidden="true"></div>
          <a href="/about">About</a>
          <a href="/work">Work</a>
          <a href="#tools">Tools</a>
          <a href="/contact">More</a>
        </div>
        <div class="site-nav__actions">
          <button class="site-nav__cta" id="contact-trigger">Get in touch</button>
          <a
            href="https://github.com/Hale730/hayden-portfolio-site"
            class="site-nav__icon"
            aria-label="View source on GitHub"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
        </div>
      </div>
    </nav>

    <div class="contact-modal" id="contact-modal" aria-modal="true" role="dialog" aria-label="Contact" hidden>
      <div class="contact-modal__backdrop" id="contact-backdrop"></div>
      <div class="contact-modal__card">
        <div class="contact-modal__header">
          <span class="contact-modal__title">Contact Me</span>
          <button class="contact-modal__close" id="contact-close" aria-label="Close">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="2" y1="2" x2="14" y2="14"/>
              <line x1="14" y1="2" x2="2" y2="14"/>
            </svg>
          </button>
        </div>
        <div class="contact-modal__divider"></div>
        <ul class="contact-modal__list">
          <li class="contact-modal__item">
            <span class="contact-modal__icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="M2 7l10 7 10-7"/>
              </svg>
            </span>
            <a href="mailto:haleporter730@gmail.com" class="contact-modal__link">haleporter730@gmail.com</a>
          </li>
          <li class="contact-modal__item">
            <span class="contact-modal__icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
            </span>
            <a href="https://www.instagram.com/hayden_porterr/" target="_blank" rel="noopener noreferrer" class="contact-modal__link">@hayden_porterr</a>
          </li>
          <li class="contact-modal__item">
            <span class="contact-modal__icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
            </span>
            <a href="https://www.youtube.com/@hale_naw" target="_blank" rel="noopener noreferrer" class="contact-modal__link">Hale</a>
          </li>
          <li class="contact-modal__item">
            <span class="contact-modal__icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </span>
            <a href="https://www.linkedin.com/in/hayden-porter-075a14293" target="_blank" rel="noopener noreferrer" class="contact-modal__link">LinkedIn</a>
          </li>
        </ul>
      </div>
    </div>

    <slot />

    <script>
      // Nav hover box: slides down on first enter, slides sideways between links,
      // slides up on leave. Never goes up-then-down when crossing between links.
      const hoverBox = document.querySelector<HTMLElement>('.site-nav__hover-box');
      const linksContainer = document.querySelector<HTMLElement>('.site-nav__links');
      const navLinks = linksContainer
        ? Array.from(linksContainer.querySelectorAll<HTMLElement>('a'))
        : [];

      if (hoverBox && linksContainer && navLinks.length) {
        let isInside = false;

        const moveTo = (link: HTMLElement) => {
          const containerRect = linksContainer.getBoundingClientRect();
          const linkRect = link.getBoundingClientRect();
          hoverBox.style.left = `${linkRect.left - containerRect.left}px`;
          hoverBox.style.width = `${linkRect.width}px`;
        };

        navLinks.forEach((link) => {
          link.addEventListener('mouseenter', () => {
            if (!isInside) {
              // Entering from outside: snap position without transition, then slide down.
              hoverBox.style.transition = 'transform 0.25s cubic-bezier(0.16, 1, 0.3, 1)';
              moveTo(link);
              hoverBox.style.transform = 'translateY(-100%)';
              // Force reflow so the browser registers the start state before animating.
              hoverBox.offsetHeight;
              hoverBox.style.transition = '';
              hoverBox.style.transform = 'translateY(0)';
              isInside = true;
            } else {
              // Moving between links: slide horizontally only, no vertical movement.
              moveTo(link);
            }
          });
        });

        linksContainer.addEventListener('mouseleave', () => {
          hoverBox.style.transform = 'translateY(-100%)';
          isInside = false;
        });
      }

      const modal = document.getElementById('contact-modal');
      const trigger = document.getElementById('contact-trigger');
      const closeBtn = document.getElementById('contact-close');
      const backdrop = document.getElementById('contact-backdrop');

      const openModal = () => { if (modal) modal.hidden = false; };
      const closeModal = () => { if (modal) modal.hidden = true; };

      trigger?.addEventListener('click', openModal);
      closeBtn?.addEventListener('click', closeModal);
      backdrop?.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

      const revealEls = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if (revealEls.length && 'IntersectionObserver' in window) {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
        );
        revealEls.forEach((el) => revealObserver.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('is-revealed'));
      }
    </script>
  </body>
</html>
