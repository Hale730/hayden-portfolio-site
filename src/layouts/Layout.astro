---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hayden Porter — Portfolio',
  description = 'AET @ UT Austin. Game Dev. Digital Creator. World-maker.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <nav class="site-nav">
      <div class="site-nav__inner">
        <div class="site-nav__brand-slot">
          <span class="site-nav__label">Creative Portfolio</span>
        </div>
        <div class="site-nav__links">
          <div class="site-nav__hover-box" aria-hidden="true"></div>
          <a href="/about">About</a>
          <a href="/work">Work</a>
          <a href="#tools">Tools</a>
          <a href="/contact">More</a>
        </div>
        <div class="site-nav__actions">
          <a href="/contact" class="site-nav__cta">Get in touch</a>
          <a
            href="https://github.com/Hale730/hayden-portfolio-site"
            class="site-nav__icon"
            aria-label="View source on GitHub"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <script>
      // Nav hover box: slides down on first enter, slides sideways between links,
      // slides up on leave. Never goes up-then-down when crossing between links.
      const hoverBox = document.querySelector<HTMLElement>('.site-nav__hover-box');
      const linksContainer = document.querySelector<HTMLElement>('.site-nav__links');
      const navLinks = linksContainer
        ? Array.from(linksContainer.querySelectorAll<HTMLElement>('a'))
        : [];

      if (hoverBox && linksContainer && navLinks.length) {
        let isInside = false;

        const moveTo = (link: HTMLElement) => {
          const containerRect = linksContainer.getBoundingClientRect();
          const linkRect = link.getBoundingClientRect();
          hoverBox.style.left = `${linkRect.left - containerRect.left}px`;
          hoverBox.style.width = `${linkRect.width}px`;
        };

        navLinks.forEach((link) => {
          link.addEventListener('mouseenter', () => {
            if (!isInside) {
              // Entering from outside: snap position without transition, then slide down.
              hoverBox.style.transition = 'transform 0.25s cubic-bezier(0.16, 1, 0.3, 1)';
              moveTo(link);
              hoverBox.style.transform = 'translateY(-100%)';
              // Force reflow so the browser registers the start state before animating.
              hoverBox.offsetHeight;
              hoverBox.style.transition = '';
              hoverBox.style.transform = 'translateY(0)';
              isInside = true;
            } else {
              // Moving between links: slide horizontally only, no vertical movement.
              moveTo(link);
            }
          });
        });

        linksContainer.addEventListener('mouseleave', () => {
          hoverBox.style.transform = 'translateY(-100%)';
          isInside = false;
        });
      }

      const revealEls = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if (revealEls.length && 'IntersectionObserver' in window) {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
        );
        revealEls.forEach((el) => revealObserver.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('is-revealed'));
      }
    </script>
  </body>
</html>
