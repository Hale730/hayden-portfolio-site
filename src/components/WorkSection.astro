---
import type { ImageMetadata } from 'astro';
import palimpsestHero from '../assets/Palimpsest Assets/Library Hero.png';

type Recent = {
  title: string;
  subtitle: string;
  href: string;
  accent: string;
  image?: ImageMetadata;
};

// Two featured "recent" projects. Drop an image into src/assets and add it to
// the `image` field to replace a card's gradient placeholder.
const recent: Recent[] = [
  {
    title: 'Palimpsest',
    subtitle: 'Point-and-click narrative horror in Godot. Shown at the UT AET Showcase, 2026.',
    href: '/work',
    accent: '#3E2F2A',
    image: palimpsestHero,
  },
  {
    title: 'Increment',
    subtitle: 'A mobile-first workout tracker running on a single Cloudflare Worker.',
    href: '/work',
    accent: '#1E3A8A',
  },
];
---

<section class="work" id="work">
  <div class="work__inner">
    <header class="work__header">
      <span class="work__eyebrow" data-reveal>Recent Work</span>
      <h2 class="work__heading" data-reveal style="--reveal-delay: 120;">
        What I&rsquo;ve been building.
      </h2>
    </header>

    <div class="work__grid">
      {
        recent.map((project, i) => (
          <a
            href={project.href}
            class="work__card"
            data-reveal
            style={`--reveal-delay: ${220 + i * 130}; --accent: ${project.accent};`}
          >
            <div class="work__card-media">
              {project.image ? (
                <img src={project.image.src} alt={project.title} loading="lazy" />
              ) : (
                <div class="work__card-placeholder">
                  <span>Image Needed</span>
                </div>
              )}
            </div>
            <div class="work__card-body">
              <h3 class="work__card-title">{project.title}</h3>
              <p class="work__card-sub">{project.subtitle}</p>
            </div>
          </a>
        ))
      }
    </div>

    <div class="work__more" data-reveal style="--reveal-delay: 500;">
      <a href="/work" class="work__more-btn">
        Explore more work
        <span class="work__more-arrow" aria-hidden="true">&#8594;</span>
      </a>
    </div>
  </div>
</section>

<style>
  .work {
    position: relative;
    z-index: 2;
    background: transparent;
    min-height: 100svh;
    padding: clamp(8rem, 18vh, 14rem) 2rem;
    display: flex;
    align-items: center;
  }

  .work__inner {
    max-width: 1180px;
    width: 100%;
    margin: 0;
  }

  .work__header {
    margin-bottom: 2.5rem;
  }

  .work__eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.55);
    margin-bottom: 0.75rem;
  }

  .work__heading {
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.025em;
    color: #000000;
    line-height: 1.1;
    text-shadow:
      0 0 60px rgba(255, 255, 255, 0.7),
      0 2px 20px rgba(255, 255, 255, 0.6);
  }

  .work__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }

  /* Clean light card: media on top, title + subtitle below. */
  .work__card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
    transition:
      transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.95s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work__card.is-revealed:hover,
  .work__card.is-revealed:focus-visible {
    transform: translateY(-6px);
    box-shadow: 0 22px 55px rgba(0, 0, 0, 0.18);
    outline: none;
  }

  .work__card-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #0b0b0f;
  }

  .work__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work__card:hover .work__card-media img,
  .work__card:focus-visible .work__card-media img {
    transform: scale(1.04);
  }

  .work__card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ececef;
    border: 2px dashed rgba(0, 0, 0, 0.2);
  }

  .work__card-placeholder span {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.4);
  }

  .work__card-body {
    padding: 1.5rem 1.5rem 1.75rem;
  }

  .work__card-title {
    font-family: 'DM Serif Display', serif;
    font-size: 1.6rem;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: #000000;
    margin-bottom: 0.45rem;
  }

  .work__card-sub {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(0, 0, 0, 0.6);
  }

  .work__more {
    margin-top: 2.75rem;
  }

  .work__more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #ffffff;
    background: #0b0b0f;
    padding: 0.9rem 1.85rem;
    border-radius: 100px;
    text-decoration: none;
    transition:
      background 0.2s ease,
      gap 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work__more-btn:hover {
    background: #000000;
    gap: 0.8rem;
  }

  .work__more-arrow {
    font-size: 1.05rem;
    line-height: 1;
  }

  @media (min-width: 768px) {
    .work__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
</style>
