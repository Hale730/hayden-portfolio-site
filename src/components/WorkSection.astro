---
import cloudflareImg from '../assets/Project Assets/Cloudflare/cloudflarethumbnail.webp';
import incrementImg from '../assets/Project Assets/Increment/Increment_Thumbnail.png';
import millfieldImg from '../assets/millfield_assets/Millfield_Project_Assets/Townhall.png';

const items = [
  {
    tag: 'Internship · Product · Summer 2026',
    title: 'Cloudflare Internship',
    description:
      'Incoming Product Manager intern at Cloudflare, working on the edge network platform team.',
    href: '/work/cloudflare-internship',
    image: cloudflareImg.src,
    imageAlt: 'Cloudflare internship',
  },
  {
    tag: 'Full-stack · Cloudflare Workers · 2026',
    title: 'Increment',
    description:
      'A mobile-first PWA workout tracker running as a single Cloudflare Worker on the edge. Google sign-in, session logging, analytics, a weekly plan builder, and an exercise library — built solo across the whole stack with D1 and Chart.js.',
    href: '/work/increment',
    image: incrementImg.src,
    imageAlt: 'Increment workout tracker',
  },
  {
    tag: 'ARG · Vanilla Web · 2026',
    title: 'Millfield County',
    description:
      'An alternate reality game disguised as a calm 2002 county government website. Log into the staff intranet, dig through a restricted cold-case archive, and dial a working touch-tone phone that rewrites the homepage.',
    href: '/work/millfield-county',
    image: millfieldImg.src,
    imageAlt: 'Millfield County town hall',
  },
];
---

<section class="work" id="work">
  <div class="work__header" data-reveal>
    <span class="work__eyebrow">Recent Work</span>
    <h2 class="work__heading">What I&rsquo;ve been building.</h2>
  </div>

  <div class="work__list">
    {items.map((item, i) => (
      <a
        href={item.href}
        class="work__item"
        data-reveal
        style={`--reveal-delay: ${i * 150};`}
      >
        <div class="work__item-media">
          {item.image ? (
            <img src={item.image} alt={item.imageAlt} loading="lazy" />
          ) : (
            <div class="work__item-placeholder" />
          )}
        </div>
        <div class="work__item-body">
          <span class="work__item-tag">{item.tag}</span>
          <h3 class="work__item-title">{item.title}</h3>
          <p class="work__item-desc">{item.description}</p>
          <span class="work__item-cta">
            View project
            <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="2" y1="8" x2="14" y2="8"/>
              <polyline points="8,2 14,8 8,14"/>
            </svg>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="work__more" data-reveal style="--reveal-delay: 500;">
    <a href="/work" class="work__more-btn">
      Explore all work
      <span aria-hidden="true">&#8594;</span>
    </a>
  </div>
</section>

<style>
  .work {
    position: relative;
    z-index: 2;
    padding: clamp(6rem, 14vh, 10rem) 2rem clamp(4rem, 8vh, 6rem);
  }

  .work__header {
    max-width: 1180px;
    margin: 0 auto 3rem;
  }

  .work__eyebrow {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.45);
    margin-bottom: 0.75rem;
  }

  .work__heading {
    font-size: clamp(2rem, 5vw, 3rem);
    letter-spacing: -0.025em;
    color: #000000;
    line-height: 1.1;
    text-shadow: 0 0 60px rgba(255, 255, 255, 0.7);
  }

  .work__list {
    max-width: 1180px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .work__item {
    display: grid;
    grid-template-columns: 1fr;
    background: #ffffff;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px dotted rgba(0, 0, 0, 0.25);
    transition: background 0.2s ease;
  }

  .work__item.is-revealed:hover {
    background: rgba(0, 0, 0, 0.02);
  }

  .work__item-media {
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.04);
    flex-shrink: 0;
    border-bottom: 1px dotted rgba(0, 0, 0, 0.15);
  }

  .work__item-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work__item.is-revealed:hover .work__item-media img {
    transform: scale(1.03);
  }

  .work__item-placeholder {
    width: 100%;
    height: 100%;
  }

  .work__item-body {
    padding: 2rem 2.25rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .work__item-tag {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.4);
  }

  .work__item-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #000000;
    margin-top: 0.1rem;
  }

  .work__item-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(0, 0, 0, 0.6);
    max-width: 560px;
    margin-top: 0.2rem;
  }

  .work__item-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.45);
    margin-top: 0.4rem;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .work__item.is-revealed:hover .work__item-cta {
    gap: 0.7rem;
    color: #000000;
  }

  .work__more {
    max-width: 1180px;
    margin: 2.5rem auto 0;
  }

  .work__more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #000000;
    background: transparent;
    padding: 0.85rem 1.6rem;
    border: 1px dotted rgba(0, 0, 0, 0.4);
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      gap 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work__more-btn:hover {
    border-color: #000000;
    gap: 0.8rem;
  }

  @media (min-width: 768px) {
    .work__item {
      grid-template-columns: 55% 1fr;
    }

    .work__item-media {
      aspect-ratio: auto;
      min-height: 320px;
      border-bottom: none;
      border-right: 1px dotted rgba(0, 0, 0, 0.15);
    }
  }

  @media (min-width: 1024px) {
    .work__item {
      grid-template-columns: 58% 1fr;
    }

    .work__item-media {
      min-height: 380px;
    }

    .work__item-body {
      padding: 2.5rem 3rem 3rem;
    }
  }
</style>
