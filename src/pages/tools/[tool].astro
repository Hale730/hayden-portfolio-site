---
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import ShaderBackground from '../../components/ShaderBackground.jsx';

const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/Logos/*.png',
  { eager: true }
);

// Tool data references logos by path; resolve to the real bundled asset by filename.
function resolveLogo(path: string): string {
  const file = path.split('/').pop() ?? '';
  const entry = Object.entries(logoModules).find(([p]) => p.endsWith(`/${file}`));
  return entry ? entry[1].default.src : '';
}

