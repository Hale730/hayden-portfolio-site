const { tool } = Astro.props;
const logoSrc = resolveLogo(tool.logo);
---

<Layout title={`${tool.name} — Hayden Porter`}>
  <ShaderBackground client:only="react" />

  <main class="tool-page">
    <a href="/#tools" class="tool-page__back">← Back</a>
    <div class="tool-page__inner">
      <div class="tool-page__header">
        <div class="tool-page__logo">
          <img src={logoSrc} alt={tool.name} />
        </div>
        <div class="tool-page__meta">
          <span class="tool-page__category">{tool.category}</span>
          <h1 class="tool-page__name">{tool.name}</h1>
          <p class="tool-page__blurb">{tool.blurb}</p>
        </div>
      </div>
      <div class="tool-page__projects">
        <span class="tool-page__eyebrow">Used In</span>
        {
          tool.projects.map((p) => (
            <a href={p.href} class="tool-page__project-link">
              <span class="tool-page__project-name">{p.name}</span>
              <span class="tool-page__project-desc">{p.desc}</span>
            </a>
          ))
        }
      </div>
    </div>
  </main>
</Layout>

<style>
  .tool-page {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    padding: 6rem 4rem 4rem;
    background: transparent;
  }

  .tool-page__back {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(0,0,0,0.55);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 4rem;
    transition: color 0.2s ease;
  }
  .tool-page__back:hover { color: #000000; }

  .tool-page__inner {
    max-width: 1180px;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .tool-page__header {
    display: flex;
    align-items: flex-start;
    gap: 3rem;
  }

  .tool-page__logo {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    padding: 16px;
    background: rgba(0,0,0,0.04);
    border: 1px solid rgba(0,0,0,0.08);
  }

  .tool-page__logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .tool-page__meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tool-page__category {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0,0,0,0.55);
  }

  .tool-page__name {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    color: #000000;
    margin: 0;
    text-shadow: 0 0 60px rgba(255,255,255,0.7);
  }

  .tool-page__blurb {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(0,0,0,0.7);
    max-width: 560px;
    text-shadow: 0 1px 12px rgba(255,255,255,0.7);
  }

  .tool-page__projects {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tool-page__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(0,0,0,0.55);
    margin-bottom: 0.5rem;
  }

  .tool-page__project-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem 1.5rem;
    background: rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.07);
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .tool-page__project-link:hover {
    background: rgba(0,0,0,0.06);
    border-color: rgba(0,0,0,0.15);
  }

  .tool-page__project-name {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: #000000;
  }

  .tool-page__project-desc {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: rgba(0,0,0,0.65);
  }

  @media (max-width: 768px) {
    .tool-page {
      padding: 5rem 1.5rem 3rem;
    }

    .tool-page__header {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
</style>
