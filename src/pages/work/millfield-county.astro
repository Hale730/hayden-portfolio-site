---
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';

// Pull every background frame and sort by filename so the sequence is in order.
const modules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/millfield_assets/millfield_background/*.jpg',
  { eager: true }
);

const frames = Object.entries(modules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default.src);
---

<Layout title="Millfield County — Hayden Porter">
  <!-- Scroll-scrubbed image sequence drawn to a single fixed canvas. -->
  <canvas id="mc-seq" class="mc-seq" aria-hidden="true"></canvas>

  <main class="mc">
    <a href="/work" class="mc__back">&#8592; All work</a>

    <section class="mc__panel">
      <span class="mc__eyebrow">Millfield County · ARG</span>
      <h1 class="mc__title">Welcome to Millfield County</h1>
      <p class="mc__lead">
        Filler copy so there&rsquo;s enough to scroll and watch the background
        sequence play. Replace all of this with the real Millfield content.
      </p>
    </section>

    <section class="mc__panel">
      <h2 class="mc__h2">A quiet 2002 county portal</h2>
      <p class="mc__body">
        Lorem ipsum placeholder text. Scroll down and the frames advance with you.
        Pellentesque habitant morbi tristique senectus et netus et malesuada fames
        ac turpis egestas. Vestibulum tortor quam, feugiat vitae, ultricies eget.
      </p>
    </section>

    <section class="mc__panel">
      <h2 class="mc__h2">The staff intranet</h2>
      <p class="mc__body">
        More filler. Aenean ultricies mi vitae est. Mauris placerat eleifend leo.
        Quisque sit amet est et sapien ullamcorper pharetra. Vestibulum erat wisi,
        condimentum sed, commodo vitae, ornare sit amet, wisi.
      </p>
    </section>

    <section class="mc__panel">
      <h2 class="mc__h2">A cold case in the archive</h2>
      <p class="mc__body">
        Keep scrolling to see the full range of the sequence. Aenean fermentum,
        elit eget tincidunt condimentum, eros ipsum rutrum orci, sagittis tempus
        lacus enim ac dui. Donec non enim in turpis pulvinar facilisis.
      </p>
    </section>

    <section class="mc__panel">
      <h2 class="mc__h2">The touch-tone dialer</h2>
      <p class="mc__body">
        Filler section. Ut wisi enim ad minim veniam, quis nostrud exerci tation
        ullamcorper suscipit lobortis nisl ut aliquip ex ea commodo consequat.
      </p>
    </section>

    <section class="mc__panel mc__panel--end">
      <h2 class="mc__h2">End of the reel</h2>
      <p class="mc__body">
        This is the last filler block, so the sequence should land on its final
        frame right about here.
      </p>
    </section>
  </main>
</Layout>

<style>
  .mc-seq {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    display: block;
    background: #0b0b0f;
  }

  .mc {
    position: relative;
    z-index: 2;
    color: #ffffff;
    padding: 0 2rem;
  }

  .mc__back {
    position: fixed;
    top: 5rem;
    left: 2rem;
    z-index: 3;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.8);
  }

  .mc__panel {
    min-height: 100vh;
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.85);
  }

  .mc__panel--end {
    min-height: 60vh;
  }

  .mc__eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 1rem;
  }

  .mc__title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .mc__h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .mc__lead {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 48ch;
    color: rgba(255, 255, 255, 0.92);
  }

  .mc__body {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.8;
    max-width: 52ch;
    color: rgba(255, 255, 255, 0.88);
  }
</style>

<script is:inline define:vars={{ frames }}>
  const canvas = document.getElementById('mc-seq');
  const ctx = canvas && canvas.getContext('2d');

  if (canvas && ctx && frames.length) {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const images = new Array(frames.length);
    let current = -1;

    const frameForScroll = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const p = max > 0 ? window.scrollY / max : 0;
      const clamped = Math.min(1, Math.max(0, p));
      return Math.round(clamped * (frames.length - 1));
    };

    const draw = (i) => {
      const img = images[i];
      if (!img || !img.complete || img.naturalWidth === 0) return;
      current = i;
      const cw = canvas.width;
      const ch = canvas.height;
      const scale = Math.max(cw / img.naturalWidth, ch / img.naturalHeight);
      const w = img.naturalWidth * scale;
      const h = img.naturalHeight * scale;
      ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
    };

    const resize = () => {
      canvas.width = Math.round(window.innerWidth * dpr);
      canvas.height = Math.round(window.innerHeight * dpr);
      const i = frameForScroll();
      // force a redraw at the new size
      current = -1;
      draw(i);
    };

    // Preload every frame; draw as soon as the relevant one is ready.
    frames.forEach((src, idx) => {
      const img = new Image();
      img.onload = () => {
        if (idx === frameForScroll() || current === -1) draw(idx);
      };
      img.src = src;
      images[idx] = img;
    });

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const i = frameForScroll();
        if (i !== current) draw(i);
        ticking = false;
      });
    };

    resize();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', resize);
  }
</script>
