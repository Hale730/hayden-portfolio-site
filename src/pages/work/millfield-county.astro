---
import type { ImageMetadata } from 'astro';
import Layout from '../../layouts/Layout.astro';
import town from '../../assets/millfield_assets/Millfield_Project_Assets/Townhall.png';
import school from '../../assets/millfield_assets/Millfield_Project_Assets/Millfield_School.png';
import palimpsest from '../../assets/millfield_assets/Millfield_Project_Assets/Palimpsest Slide.png';

// Background frames for the cinematic scroll background, in sequence order.
const frameMods = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/millfield_assets/millfield_background/*.jpg',
  { eager: true }
);
const frames = Object.entries(frameMods)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([, mod]) => mod.default.src);

const tools = [
  { tool: 'VS Code', role: 'Development' },
  { tool: 'Codex', role: 'Development' },
  { tool: 'ChatGPT', role: 'Image generation' },
  { tool: 'Obsidian', role: 'Writing' },
  { tool: 'ElevenLabs', role: 'Audio production' },
  { tool: 'Cloudflare', role: 'Hosting and domain registration' },
];
---

<Layout title="Millfield County — Hayden Porter">
  <!-- Replaces the shared brand: a cliché 2002 button + the project name -->
  <a href="/work" class="mc-navback" aria-label="Back to all work">
    <span class="mc-navback__btn" aria-hidden="true">&#8592;</span>
    <span class="mc-navback__name">Millfield County</span>
  </a>

  <canvas id="mc-seq" class="mc-seq" aria-hidden="true"></canvas>
  <div class="mc-scrim" aria-hidden="true"></div>

  <div class="mc-skin">
    <div class="mc-doc">
      <section class="mc-panel">
        <h1 class="mc-panel__bar">
          <a
            class="mc-panel__bar-link"
            href="https://millfieldcounty.com"
            target="_blank"
            rel="noopener noreferrer"
          >millfieldcounty.com</a>
        </h1>
        <div class="mc-panel__body">
          <p class="mc-lead">
            An alternate reality game disguised as a small town government website.
          </p>

          <figure class="mc-fig">
            <img src={town.src} alt="The Millfield County town hall" loading="lazy" />
          </figure>

          <p>
            <a href="https://millfieldcounty.com" target="_blank" rel="noopener noreferrer"
              >millfieldcounty.com</a
            > looks like an ordinary county portal from 2002. A news
            carousel, a staff directory, a calendar, a contact page. Spend a few minutes
            clicking around and something feels wrong. Read the articles, listen to the
            voicemails, and solve the puzzle to uncover the unsettling story of Millfield
            County.
          </p>

          <figure class="mc-fig">
            <img src={school.src} alt="Millfield Middle School" loading="lazy" />
          </figure>

          <p>
            I built the site solo for my Exploring User Interaction class at UT Austin,
            where the goal was to use interface as a storytelling medium. The screens
            themselves are the puzzle. A staff intranet that you log into using a clue
            hidden in an article. A records archive that unlocks one document at a time,
            leading from a police report to four family statements to a final recorded
            interview. A working phone dialer that rewrites the homepage when you call the
            right number. Every detail is committed to its era, down to the period
            typography and a recorded voicemail behind each county phone number.
          </p>

          <figure class="mc-fig">
            <img src={palimpsest.src} alt="Palimpsest, the game set in the same town" loading="lazy" />
          </figure>

          <p>
            <a href="https://millfieldcounty.com" target="_blank" rel="noopener noreferrer"
              >millfieldcounty.com</a
            > is a spinoff of my indie horror game
            <a href="/work/palimpsest">Palimpsest</a>, which takes place in the same town
            and shares a similar tone. You can explore my other work
            <a href="/work/palimpsest">Palimpsest</a> if you are interested.
          </p>
        </div>

        <h2 class="mc-panel__bar mc-panel__bar--sub">Tools</h2>
        <div class="mc-panel__body">
          <p>Here are some of the tools I used to create this project.</p>
          <table class="mc-tools">
            <thead>
              <tr>
                <th>Tool</th>
                <th>Role</th>
              </tr>
            </thead>
            <tbody>
              {
                tools.map((row) => (
                  <tr>
                    <td>{row.tool}</td>
                    <td>{row.role}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  /* Footage background, scrubbed by page scroll */
  .mc-seq {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    display: block;
    background: #0b0b0f;
  }

  /* Dim the footage so the county page reads clearly on top of it */
  .mc-scrim {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: rgba(10, 12, 16, 0.2);
  }

  /* Header back-link */
  .mc-navback {
    position: fixed;
    top: 0;
    left: 2rem;
    padding: 0.85rem 0;
    z-index: 101;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }

  .mc-navback__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 28px;
    color: #1a1a1a;
    font-size: 1rem;
    line-height: 1;
    background: linear-gradient(180deg, #fdfdfb 0%, #d8d4ca 100%);
    border: 2px solid;
    border-top-color: #ffffff;
    border-left-color: #ffffff;
    border-right-color: #7e7a70;
    border-bottom-color: #7e7a70;
  }

  .mc-navback:hover .mc-navback__btn {
    background: linear-gradient(180deg, #ffffff 0%, #e4e0d6 100%);
  }

  .mc-navback:active .mc-navback__btn {
    border-top-color: #7e7a70;
    border-left-color: #7e7a70;
    border-right-color: #ffffff;
    border-bottom-color: #ffffff;
  }

  .mc-navback__name {
    font-family: Verdana, Geneva, Tahoma, Arial, sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    color: #ffffff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
  }

  /* Left-aligned county "page" over the footage */
  .mc-skin {
    position: relative;
    z-index: 2;
    padding: 8rem 1.5rem 5rem;
    font-family: Verdana, Geneva, Tahoma, Arial, sans-serif;
  }

  /* Tan/gray county page, holding the module panels */
  .mc-doc {
    max-width: 1080px;
    margin: 0 auto;
    padding: 1.1rem;
    background: #c7c0b0;
    border: 2px solid;
    border-top-color: #ffffff;
    border-left-color: #ffffff;
    border-right-color: #6d7683;
    border-bottom-color: #6d7683;
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.55);
    color: #26303c;
  }

  /* Blue beveled module panels */
  .mc-panel {
    background: #fbf8f1;
    border: 2px solid;
    border-top-color: #ffffff;
    border-left-color: #ffffff;
    border-right-color: #6d7683;
    border-bottom-color: #6d7683;
  }

  .mc-panel + .mc-panel {
    margin-top: 1.1rem;
  }

  .mc-panel__bar {
    margin: 0;
    background: linear-gradient(180deg, #3a6db0 0%, #285a8e 55%, #1f4570 100%);
    color: #ffffff;
    font-family: Verdana, Geneva, Tahoma, Arial, sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #16304f;
    text-shadow: 0 1px 1px rgba(0, 0, 0, 0.4);
  }

  /* Same bar reused mid-panel as a section header (Tools) */
  .mc-panel__bar--sub {
    border-top: 2px solid #16304f;
  }

  /* The site title doubles as a link to the live site, white on the bar */
  .mc-panel__bar-link {
    color: #ffffff;
    text-decoration: none;
  }

  .mc-panel__bar-link:hover {
    text-decoration: underline;
  }

  .mc-panel__body {
    padding: 1.4rem 1.5rem 1.6rem;
    font-size: 1.15rem;
    line-height: 1.7;
    color: #26303c;
  }

  .mc-panel__body > * + * {
    margin-top: 1rem;
  }

  .mc-lead {
    font-weight: 700;
    font-size: 1.4rem;
    color: #1f4570;
  }

  .mc-panel__body a {
    color: #1a4f8a;
    text-decoration: underline;
  }

  .mc-panel__body a:hover {
    color: #0f3a6b;
  }

  /* Featured images, framed like county article art */
  .mc-fig {
    max-width: 80%;
    margin: 1.25rem auto;
    border: 2px solid;
    border-top-color: #ffffff;
    border-left-color: #ffffff;
    border-right-color: #6d7683;
    border-bottom-color: #6d7683;
    background: #d8d4c8;
  }

  .mc-fig img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Period county table */
  .mc-tools {
    width: 100%;
    max-width: 520px;
    border-collapse: collapse;
    font-size: 1.05rem;
    color: #1f2a36;
    background: #ffffff;
    border: 1px solid #9aa6b2;
  }

  .mc-tools th {
    background: linear-gradient(180deg, #3a6db0 0%, #285a8e 55%, #1f4570 100%);
    color: #ffffff;
    text-align: left;
    padding: 0.45rem 0.7rem;
    border-bottom: 1px solid #16304f;
  }

  .mc-tools td {
    padding: 0.45rem 0.7rem;
    border-top: 1px solid #c8d0da;
  }

  .mc-tools tbody tr:nth-child(even) {
    background: #eef1f5;
  }

  @media (min-width: 768px) {
    .mc-skin {
      padding: 9rem 2rem 6rem;
    }
  }
</style>

<!-- Re-skin the shared nav to the Millfield county UI, only on this page.
     :has(.mc-skin) guards it so it can't affect other pages. -->
<style is:global>
  /* Drop the center nav links and brand label slot on this page. */
  html:has(.mc-skin) .site-nav__links,
  html:has(.mc-skin) .site-nav__brand-slot {
    display: none;
  }

  html:has(.mc-skin) .site-nav {
    position: fixed;
    background: linear-gradient(180deg, #3a6db0 0%, #245184 55%, #1c3e66 100%);
    border-bottom: 2px solid #16304f;
    box-shadow: inset 0 1px 0 #6f9bd4;
  }

  html:has(.mc-skin) .site-nav__actions {
    border-left: none;
  }

  html:has(.mc-skin) .site-nav__actions > * {
    border-color: rgba(255, 255, 255, 0.2);
  }

  html:has(.mc-skin) .site-nav__cta,
  html:has(.mc-skin) .site-nav__icon {
    font-family: Verdana, Geneva, Tahoma, Arial, sans-serif;
    color: #ffffff;
    opacity: 1;
  }

  html:has(.mc-skin) .site-nav__cta:hover,
  html:has(.mc-skin) .site-nav__icon:hover {
    opacity: 0.75;
  }
</style>

<script is:inline define:vars={{ frames }}>
  const canvas = document.getElementById('mc-seq');
  const ctx = canvas && canvas.getContext('2d');

  if (canvas && ctx && frames.length) {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const images = new Array(frames.length);
    let current = -1;

    const frameForScroll = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const p = max > 0 ? window.scrollY / max : 0;
      const clamped = Math.min(1, Math.max(0, p));
      return Math.round(clamped * (frames.length - 1));
    };

    const draw = (i) => {
      const img = images[i];
      if (!img || !img.complete || img.naturalWidth === 0) return;
      current = i;
      const cw = canvas.width;
      const ch = canvas.height;
      const scale = Math.max(cw / img.naturalWidth, ch / img.naturalHeight);
      const w = img.naturalWidth * scale;
      const h = img.naturalHeight * scale;
      ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
    };

    const resize = () => {
      canvas.width = Math.round(window.innerWidth * dpr);
      canvas.height = Math.round(window.innerHeight * dpr);
      current = -1;
      draw(frameForScroll());
    };

    frames.forEach((src, idx) => {
      const img = new Image();
      img.onload = () => {
        if (idx === frameForScroll() || current === -1) draw(idx);
      };
      img.src = src;
      images[idx] = img;
    });

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const i = frameForScroll();
        if (i !== current) draw(i);
        ticking = false;
      });
    };

    resize();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', resize);
  }
</script>
