---
import Layout from '../../layouts/Layout.astro';
import cfThumb from '../../assets/Project Assets/Cloudflare/cloudflarethumbnail.webp';
import cfLinkedIn from '../../assets/Project Assets/Cloudflare/CloudflareLinkedInPost.jpg';
import cfGroup from '../../assets/Project Assets/Cloudflare/InternGroupPhoto.jpg';
---

<Layout title="Cloudflare Internship — Hayden Porter">
  <div class="cf">

    <!-- ── TOP NAV ──────────────────────────────────────────────── -->
    <div class="cf-topbar">
      <a href="/work" class="cf-back">&#8592; All work</a>
    </div>

    <!-- ── HERO CARD ────────────────────────────────────────────── -->
    <section class="cf-card-wrap">
      <div class="cf-orange-card cf-hero-card">
        <div class="cf-orange-card__glow"></div>
        <div class="cf-hero-inner">
          <span class="cf-hero-eyebrow">Summer 2026 &middot; Product Manager Intern</span>
          <h1 class="cf-hero-title">
            Shipping product<br />at internet scale.
          </h1>
          <p class="cf-hero-sub">
            Ten weeks on the edge network platform team at one of the world's
            most critical internet infrastructure companies.
          </p>
          <a
            href="https://www.cloudflare.com"
            target="_blank"
            rel="noopener noreferrer"
            class="cf-pill"
          >Learn about Cloudflare</a>
        </div>
      </div>
    </section>

    <!-- ── STATS ─────────────────────────────────────────────────── -->
    <section class="cf-dark cf-stats">
      <div class="cf-inner">
        <div class="cf-stats__grid">
          <div class="cf-stat">
            <span class="cf-stat__val">10</span>
            <span class="cf-stat__label">Weeks</span>
          </div>
          <div class="cf-stat">
            <span class="cf-stat__val">PM</span>
            <span class="cf-stat__label">Role</span>
          </div>
          <div class="cf-stat">
            <span class="cf-stat__val">300+</span>
            <span class="cf-stat__label">Cities on the network</span>
          </div>
          <div class="cf-stat">
            <span class="cf-stat__val">Edge</span>
            <span class="cf-stat__label">Platform team</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ── OVERVIEW ──────────────────────────────────────────────── -->
    <section class="cf-dark cf-overview">
      <div class="cf-inner">
        <span class="cf-eyebrow">Overview</span>
        <h2 class="cf-heading">Working at the edge<br />of the internet.</h2>
        <p class="cf-body">
          Cloudflare runs one of the world's largest networks — spanning 300+ cities,
          protecting millions of websites, and processing hundreds of billions of daily
          requests. As a PM intern on the edge platform team, I worked directly on the
          developer-facing products that sit at that infrastructure layer.
        </p>
        <p class="cf-body cf-body--filler">
          [Filler — describe the specific project or initiative you owned. What problem
          did you solve? Who did you collaborate with?]
        </p>
        <div class="cf-overview__img">
          <img src={cfLinkedIn.src} alt="Cloudflare LinkedIn announcement" />
        </div>
      </div>
    </section>

    <!-- ── WHAT I WORKED ON ──────────────────────────────────────── -->
    <section class="cf-dark cf-features">
      <div class="cf-inner">
        <span class="cf-eyebrow">What I worked on</span>
        <h2 class="cf-heading">Three months.<br />Real product decisions.</h2>
        <div class="cf-features__grid">
          <div class="cf-feature">
            <div class="cf-feature__icon">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="7"/>
                <line x1="16.5" y1="16.5" x2="22" y2="22"/>
              </svg>
            </div>
            <h3 class="cf-feature__title">Discovery &amp; Research</h3>
            <p class="cf-feature__body">
              [Filler — customer interviews, competitive analysis, internal data
              deep-dives. What did you learn that surprised you?]
            </p>
          </div>
          <div class="cf-feature">
            <div class="cf-feature__icon">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="2" width="16" height="20" rx="2"/>
                <line x1="8" y1="8" x2="16" y2="8"/>
                <line x1="8" y1="12" x2="16" y2="12"/>
                <line x1="8" y1="16" x2="12" y2="16"/>
              </svg>
            </div>
            <h3 class="cf-feature__title">Spec Writing</h3>
            <p class="cf-feature__body">
              [Filler — PRDs, feature briefs, scoping sessions with engineering.
              What tradeoffs did you navigate?]
            </p>
          </div>
          <div class="cf-feature">
            <div class="cf-feature__icon">
              <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <h3 class="cf-feature__title">Launch</h3>
            <p class="cf-feature__body">
              [Filler — final demo, intern showcase, cross-team rollout. What
              shipped and what was the reception?]
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── PULL QUOTE ────────────────────────────────────────────── -->
    <section class="cf-dark cf-quote">
      <div class="cf-inner">
        <p class="cf-quote__text">
          &ldquo;[Filler &mdash; a specific, personal takeaway from the summer.
          What did working at Cloudflare teach you that you couldn&rsquo;t have
          learned anywhere else?]&rdquo;
        </p>
        <span class="cf-quote__attr">Hayden Porter &mdash; PM Intern, Cloudflare 2026</span>
      </div>
    </section>

    <!-- ── GALLERY CARD ──────────────────────────────────────────── -->
    <section class="cf-card-wrap">
      <div class="cf-orange-card cf-gallery-card">
        <div class="cf-orange-card__glow cf-orange-card__glow--top"></div>
        <div class="cf-gallery-inner">
          <span class="cf-gallery-eyebrow">From the summer</span>
          <div class="cf-gallery-grid">
            <figure class="cf-gallery-fig">
              <img src={cfGroup.src} alt="Intern cohort, Summer 2026" />
              <figcaption>Intern cohort &mdash; Summer 2026</figcaption>
            </figure>
            <figure class="cf-gallery-fig">
              <div class="cf-gallery-placeholder">
                <span>Photo coming soon</span>
              </div>
              <figcaption>[Add caption]</figcaption>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CLOSE ─────────────────────────────────────────────────── -->
    <section class="cf-dark cf-close">
      <div class="cf-inner cf-close__inner">
        <span class="cf-close__label">Cloudflare &middot; Summer 2026</span>
        <a href="/work" class="cf-close__back">&#8592; Back to all work</a>
      </div>
    </section>

  </div>
</Layout>

<style>
  /* ── TOKENS ────────────────────────────────────────────────────── */
  .cf {
    --orange: #ff5d1d;
    --dark:   #171717;
    --white:  #ffffff;
    --muted:  rgba(255, 255, 255, 0.5);
    --line:   rgba(255, 255, 255, 0.06);

    background: var(--dark);
    font-family: 'Inter', sans-serif;
    color: var(--white);
  }

  /* ── DARK SECTION BASE (with dashed column lines) ──────────────── */
  .cf-dark {
    background-color: var(--dark);
    background-image:
      repeating-linear-gradient(to bottom, var(--line) 0px, var(--line) 4px, transparent 4px, transparent 14px),
      repeating-linear-gradient(to bottom, var(--line) 0px, var(--line) 4px, transparent 4px, transparent 14px),
      repeating-linear-gradient(to bottom, var(--line) 0px, var(--line) 4px, transparent 4px, transparent 14px),
      repeating-linear-gradient(to bottom, var(--line) 0px, var(--line) 4px, transparent 4px, transparent 14px),
      repeating-linear-gradient(to bottom, var(--line) 0px, var(--line) 4px, transparent 4px, transparent 14px),
      repeating-linear-gradient(to bottom, var(--line) 0px, var(--line) 4px, transparent 4px, transparent 14px),
      repeating-linear-gradient(to bottom, var(--line) 0px, var(--line) 4px, transparent 4px, transparent 14px);
    background-size:
      1px 18px, 1px 18px, 1px 18px, 1px 18px, 1px 18px, 1px 18px, 1px 18px;
    background-position:
      12.5% 0, 25% 0, 37.5% 0, 50% 0, 62.5% 0, 75% 0, 87.5% 0;
    background-repeat: repeat-y;
    position: relative;
  }

  /* ── LAYOUT HELPERS ────────────────────────────────────────────── */
  .cf-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── TOP BAR ───────────────────────────────────────────────────── */
  .cf-topbar {
    padding: 5.5rem 2rem 0;
    max-width: 1100px;
    margin: 0 auto;
  }

  .cf-back {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cf-back:hover { color: var(--white); }

  /* ── ORANGE CARD (shared by hero + gallery) ─────────────────────── */
  .cf-card-wrap {
    padding: 1.5rem 1.5rem;
  }

  .cf-orange-card {
    background-color: var(--orange);
    /* dot matrix texture */
    background-image: radial-gradient(circle, rgba(0, 0, 0, 0.18) 1px, transparent 1px);
    background-size: 14px 14px;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
  }

  /* sunrise glow at bottom */
  .cf-orange-card__glow {
    position: absolute;
    bottom: -80px;
    left: 50%;
    transform: translateX(-50%);
    width: 70%;
    height: 280px;
    background: radial-gradient(ellipse at center, rgba(255, 220, 100, 0.55) 0%, transparent 65%);
    pointer-events: none;
  }

  /* glow at top for gallery card */
  .cf-orange-card__glow--top {
    bottom: auto;
    top: -60px;
    background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.18) 0%, transparent 65%);
  }

  /* ── HERO CARD ──────────────────────────────────────────────────── */
  .cf-hero-card {
    min-height: 72vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cf-hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 6rem 2rem 8rem;
    max-width: 820px;
    margin: 0 auto;
  }

  .cf-hero-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 1.5rem;
  }

  .cf-hero-title {
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--white);
    margin-bottom: 1.5rem;
  }

  .cf-hero-sub {
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.82);
    max-width: 50ch;
    margin: 0 auto 2.5rem;
  }

  /* ── PILL BUTTON ────────────────────────────────────────────────── */
  .cf-pill {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--dark);
    background: var(--white);
    padding: 0.85rem 2rem;
    border-radius: 100px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .cf-pill:hover { opacity: 0.88; }

  /* ── STATS ──────────────────────────────────────────────────────── */
  .cf-stats { padding: 4rem 2rem; }

  .cf-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cf-stat {
    padding: 2.5rem 2rem;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cf-stat:last-child { border-right: none; }

  .cf-stat__val {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--orange);
    line-height: 1;
  }

  .cf-stat__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── SHARED SECTION TEXT ────────────────────────────────────────── */
  .cf-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 1.25rem;
  }

  .cf-heading {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 2rem;
  }

  .cf-body {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--muted);
    max-width: 58ch;
    margin-bottom: 1rem;
  }

  .cf-body--filler { font-style: italic; }

  /* ── OVERVIEW ───────────────────────────────────────────────────── */
  .cf-overview { padding: clamp(5rem, 10vh, 8rem) 2rem; }

  .cf-overview__img {
    margin-top: 3.5rem;
    max-width: 760px;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cf-overview__img img {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  /* ── FEATURES ───────────────────────────────────────────────────── */
  .cf-features { padding: clamp(5rem, 10vh, 8rem) 2rem; }

  .cf-features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: 3.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cf-feature {
    padding: 2.5rem 2rem 2.5rem 0;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    padding-right: 2.5rem;
  }

  .cf-feature:first-child { padding-left: 0; }
  .cf-feature:last-child { border-right: none; padding-right: 0; }
  .cf-feature:not(:first-child) { padding-left: 2.5rem; }

  .cf-feature__icon {
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.25rem;
  }

  .cf-feature__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }

  .cf-feature__body {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--muted);
    font-style: italic;
  }

  /* ── PULL QUOTE ─────────────────────────────────────────────────── */
  .cf-quote { padding: clamp(5rem, 10vh, 8rem) 2rem; }

  .cf-quote__text {
    font-size: clamp(1.4rem, 3.5vw, 2.6rem);
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: var(--orange);
    max-width: 820px;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .cf-quote__attr {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--muted);
  }

  /* ── GALLERY CARD ───────────────────────────────────────────────── */
  .cf-gallery-card { padding: 4rem 2.5rem; }

  .cf-gallery-inner { position: relative; z-index: 1; }

  .cf-gallery-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 2rem;
  }

  .cf-gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .cf-gallery-fig { margin: 0; }

  .cf-gallery-fig img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-radius: 8px;
  }

  .cf-gallery-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: rgba(0, 0, 0, 0.15);
    border: 1px dashed rgba(255, 255, 255, 0.3);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cf-gallery-placeholder span {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .cf-gallery-fig figcaption {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.6rem;
    padding-left: 0.1rem;
  }

  /* ── CLOSE ──────────────────────────────────────────────────────── */
  .cf-close { padding: 4rem 2rem 6rem; }

  .cf-close__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cf-close__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .cf-close__back {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .cf-close__back:hover { color: var(--white); }

  /* ── RESPONSIVE ─────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .cf-stats__grid { grid-template-columns: repeat(2, 1fr); }
    .cf-stat:nth-child(2) { border-right: none; }
    .cf-stat:nth-child(3),
    .cf-stat:nth-child(4) { border-top: 1px solid rgba(255, 255, 255, 0.08); }

    .cf-features__grid { grid-template-columns: 1fr; }
    .cf-feature {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding: 2rem 0 !important;
    }
    .cf-feature:last-child { border-bottom: none; }

    .cf-gallery-grid { grid-template-columns: 1fr; }

    .cf-close__inner { flex-direction: column; gap: 1rem; align-items: flex-start; }
  }

  @media (max-width: 600px) {
    .cf-card-wrap { padding: 1rem; }
    .cf-hero-card { min-height: 85vh; }
    .cf-stats__grid { grid-template-columns: 1fr 1fr; }
  }
</style>
